# ==============================================================================
# SALES RPG AI - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your credentials

# ------------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# ------------------------------------------------------------------------------
# Options: "github", "gemini", "openrouter", "local", "azure", "azure_ai", "openai"
LLM_PROVIDER=github

# ------------------------------------------------------------------------------
# GITHUB MODELS (FREE TIER - RECOMMENDED FOR GETTING STARTED)
# ------------------------------------------------------------------------------
# Get your token: https://github.com/settings/tokens
# Required scope: models:read
# Endpoint: https://models.github.ai/inference
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_MODEL=gpt-4o-mini  # Options: gpt-4o, gpt-4o-mini, meta-llama-3.1-405b-instruct, etc.

# ------------------------------------------------------------------------------
# GOOGLE GEMINI (RECOMMENDED FOR PRODUCTION)
# ------------------------------------------------------------------------------
# Get your key: https://aistudio.google.com/apikey
# OpenAI-compatible endpoint — no SDK changes needed
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash  # Options: gemini-2.0-flash, gemini-2.5-pro, gemini-2.5-flash

# ------------------------------------------------------------------------------
# OPENROUTER (FREE & PAID MODELS)
# ------------------------------------------------------------------------------
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ------------------------------------------------------------------------------
# AZURE AI / OPENAI (PRODUCTION)
# ------------------------------------------------------------------------------
# For Azure AI, get credentials from Azure portal
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o  # Your deployment name
AZURE_API_VERSION=2024-08-01-preview

# For direct OpenAI (not Azure)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# LOCAL AI (PRIVACY-FOCUSED, NO API COSTS)
# ------------------------------------------------------------------------------
LOCAL_AI_BASE_URL=http://localhost:8080/v1
LOCAL_AI_MODEL=phi-3.5-mini

# ------------------------------------------------------------------------------
# TRANSCRIPTION ENGINE
# ------------------------------------------------------------------------------
# Options: "vad" (local Silero VAD + faster-whisper, recommended)
#          "whisperlivekit" (WebSocket relay, requires whisper-live container)
TRANSCRIPTION_ENGINE=vad

# VadTranscriber settings (when TRANSCRIPTION_ENGINE=vad)
VAD_WHISPER_MODEL=base    # tiny, base, small, medium, large-v3
VAD_DEVICE=cpu            # cpu or cuda (cuda needs ~5GB VRAM)
VAD_SILENCE_MS=400        # Silence threshold before transcribing

# WhisperLiveKit settings (when TRANSCRIPTION_ENGINE=whisperlivekit)
WHISPER_HOST=localhost
WHISPER_PORT=9090

# ------------------------------------------------------------------------------
# QUICK START GUIDE
# ------------------------------------------------------------------------------
# 1. GitHub Models (FREE, no credit card):
#    - Set LLM_PROVIDER=github
#    - Create PAT at: https://github.com/settings/tokens
#    - Enable "models:read" scope
#    - Set GITHUB_TOKEN=ghp_your_token
#
# 2. Google Gemini (PRODUCTION):
#    - Set LLM_PROVIDER=gemini
#    - Get key at: https://aistudio.google.com/apikey
#    - Set GEMINI_API_KEY=your-key
#
# 3. OpenRouter (FREE tier available):
#    - Set LLM_PROVIDER=openrouter
#    - Get key at: https://openrouter.ai/keys
#    - Set OPENROUTER_API_KEY=sk-or-v1-your-key
#
# 4. Azure AI (ENTERPRISE):
#    - Set LLM_PROVIDER=azure
#    - Get Azure OpenAI credentials from portal
#    - Set AZURE_OPENAI_* variables
#
# 5. Local (OFFLINE):
#    - Set LLM_PROVIDER=local
#    - Run LocalAI container (see README)
